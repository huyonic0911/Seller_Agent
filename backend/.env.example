# ===== Nhà cung cấp LLM =====
# qwen      : Qwen self-host qua Ollama (mặc định) — hoặc bất kỳ endpoint OpenAI-compatible
# finetuned : model đã fine-tune (GGUF trên Ollama hoặc vLLM) — cũng OpenAI-compatible
# anthropic : Claude (cần ANTHROPIC_API_KEY)
# offline   : trả lời template (không cần model), để demo UI/giọng nói
LLM_PROVIDER=qwen

# ----- Qwen self-host (Ollama trên RTX 5060) -----
# Ollama expose sẵn endpoint OpenAI-compatible ở /v1
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
# RTX 5060 8GB: qwen2.5:7b (Q4 vừa đủ) — nếu thiếu VRAM/chậm, đổi qwen2.5:3b
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# ----- Model đã fine-tune (khi LLM_PROVIDER=finetuned) -----
# Cách A (Ollama-GGUF): merge_export.py → `ollama create seller-qwen3:8b -f Modelfile`
#   giữ OPENAI_BASE_URL ở Ollama, đặt LLM_MODEL=seller-qwen3:8b
# Cách B (vLLM, throughput cao): serve merged 16-bit rồi trỏ:
#   OPENAI_BASE_URL=http://<vllm-host>:8000/v1 ; LLM_MODEL=<tên-served>
# LLM_MODEL=seller-qwen3:8b

# ----- Anthropic (chỉ khi LLM_PROVIDER=anthropic; cũng dùng cho sinh data & judge) -----
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_EFFORT=low

# ===== Thu thập dữ liệu fine-tune (flywheel) =====
# Bật để ghi log tương tác comment→reply (JSONL) làm data train vòng sau.
INTERACTION_LOG=false
# INTERACTION_LOG_DIR=logs/interactions

# ===== TTS tiếng Việt =====
# vixtts = voice cloning giọng riêng (GPU, tự nhiên nhất) — xem README
# piper  = local, nhanh, cắm .onnx
# espeak = local, dễ nhất (sudo apt install espeak-ng), giọng máy móc
# edge   = cloud Microsoft (hay lỗi NoAudioReceived)
TTS_ENGINE=vixtts
TTS_ENABLED=true

# --- viXTTS (khi TTS_ENGINE=vixtts) ---
VIXTTS_MODEL_DIR=models/viXTTS               # thư mục model tải từ capleaf/viXTTS
VIXTTS_SPEAKER_WAV=voices/my_voice.wav       # MẪU giọng nữ mục tiêu (giọng sẽ được clone)
VIXTTS_LANGUAGE=vi
VIXTTS_DEVICE=cuda                           # cuda | cpu
VIXTTS_TEMPERATURE=0.7

# --- espeak-ng (khi TTS_ENGINE=espeak) ---
ESPEAK_BIN=espeak-ng
ESPEAK_VOICE=vi
ESPEAK_SPEED=160

# --- Piper (local, khi TTS_ENGINE=piper) ---
# Tải binary piper + voice .onnx theo README. PIPER_BIN có thể là đường dẫn tuyệt đối.
PIPER_BIN=piper
PIPER_MODEL=voices/vi_VN-vais1000-medium.onnx
PIPER_LENGTH_SCALE=1.0   # <1 đọc nhanh hơn, >1 chậm hơn

# --- edge-tts (khi TTS_ENGINE=edge) ---
# Nữ: vi-VN-HoaiMyNeural | Nam: vi-VN-NamMinhNeural
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_RATE=+8%

# ===== RAG (module llm): bge-m3 self-host + Qdrant =====
RAG_ENABLED=true
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu                   # cpu | cuda (cpu để không tranh VRAM với viXTTS)
RAG_TOP_K=4
QDRANT_URL=http://localhost:6333   # rỗng -> chế độ nhúng local theo QDRANT_PATH
QDRANT_PATH=qdrant_data
QDRANT_COLLECTION=products

# ===== Vision (avatar) =====
AVATAR_TYPE=live2d                 # svg | live2d | 3d
# AVATAR_MODEL=/models/hiyori/hiyori_pro_t11.model3.json
VISEME_ENABLED=true
VISEME_FPS=30

# ===== Khác =====
# PRODUCTS_PATH=data/samsung_phones.json   # nguồn danh mục (RAG + catalog)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
